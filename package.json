{
  "name": "price-watch",
  "private": true,
  "version": "0.1.0",
  "description": "Local price tracking and alert runner",
  "engines": {
    "node": ">=20.15"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^11.0.3",
    "@nestjs/core": "^11.0.3",
    "mysql2": "^3.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "infra": "docker compose up -d",
    "start": "tsx src/main.ts",
    "api": "tsx src/main.ts --api",
    "once": "tsx src/main.ts --once",
    "check-config": "tsx src/main.ts --validate",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start:prod": "node dist/main.js"
  }
}
