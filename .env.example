# ── Database ──────────────────────────────────────────────────────────────────
# For local dev (no Docker): point to your local MySQL instance
DB_HOST=127.0.0.1
# DB_PORT is the HOST port that maps to MySQL 3306 inside Docker
DB_PORT=3308
DB_USER=price_watch
DB_PASSWORD=price_watch_dev
DB_NAME=price_watch
DB_CONNECTION_LIMIT=10

# ── API Server ────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=4000

# ── Docker Compose ports ─────────────────────────────────────────────────────
# Host port for the frontend (nginx)
UI_PORT=80
# MySQL root password (Docker only)
DB_ROOT_PASSWORD=root

# ── LLM (Gemini) — added via UI after startup ─────────────────────────────────
# GEMINI_API_KEY=your-key-here   ← managed in DB, not needed here
